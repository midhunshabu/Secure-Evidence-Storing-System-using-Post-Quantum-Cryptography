# Runtime environment
APP_ENV=development
PORT=5000

# Secrets (required in production)
SECRET_KEY=replace-with-strong-random-secret
JWT_SECRET_KEY=replace-with-strong-random-jwt-secret
AADHAR_HASH_PEPPER=replace-with-strong-random-pepper
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=false
APP_DATA_ENCRYPTION_KEY=replace-with-fernet-key
KEY_VAULT_MASTER_KEY=replace-with-fernet-key
KEY_VAULT_DIR=secure/key_vault

# Database
DATABASE_URL=sqlite:///pqc_evidence_dev.db
DB_POOL_RECYCLE=1800

# Upload and limits
UPLOAD_FOLDER=storage/evidence
MAX_CONTENT_LENGTH=524288000

# Auth challenge
CHALLENGE_TTL_SECONDS=300
SERVER_GENERATES_CLIENT_AUTH_SECRET=true

# PQC hardening
PQC_ALLOW_INSECURE_FALLBACK=false

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate limits
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=300 per hour
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_STRATEGY=fixed-window
RATELIMIT_LOGIN_CHALLENGE=10 per minute
RATELIMIT_LOGIN_VERIFY=5 per minute
RATELIMIT_EVIDENCE_UPLOAD=60 per hour
RATELIMIT_EVIDENCE_GET=300 per hour

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Startup behavior
AUTO_CREATE_DB=true
FORCE_HTTPS_HEADERS=false
DEV_LOGIN_ALLOW_CHALLENGE_ECHO=true
